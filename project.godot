[layer_names]

3d_render/layer_15="No Occlusion"
3d_render/layer_20="Editor Only"
3d_physics/layer_1="All"
3d_physics/layer_2="Player"
3d_physics/layer_3="Npc"

[navigation]

3d/default_cell_size=0.2
3d/default_cell_height=0.2

[physics]

3d/physics_engine="Jolt Physics"
common/physics_interpolation=true

[rendering]

rendering_device/fallback_to_vulkan=false
rendering_device/fallback_to_d3d12=false
rendering_device/fallback_to_opengl3=false
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=3
occlusion_culling/use_occlusion_culling=true
