{
    "explorer.fileNesting.enabled": true,
    "explorer.compactFolders": false,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        "*.gd": "${capture}.gd.uid",
        "*.cs": "${capture}.cs.uid",
    },
    "editor.semanticTokenColorCustomizations": {
        "[Default Dark Modern]": {
            "rules": {
                "enum": "#b8d7a3",
                "interface": "#b8d7a3",
                "struct": "#86C691",
                "type": "#86C691",
                "namespace": "#dcdcdc",
                "operator": "#b4b4b4",
                "xmlDocCommentAttributeName": "#c8c8c8",
                "field.static": "#dcdcdc",
                "typeParameter": "#b0d79a",
                "property": "#dcdcdc",
                "constant.static": "#dcdcdc",
                "preprocessorText": "#dcdcdc",
                "macro": "#9b9b9b",
                "comment": "#45a64a",
            }
        }
    },
    "editor.bracketPairColorization.enabled": false,
    "files.exclude": {
        ".vs/": true,
        ".godot/": true,
        ".unary/": true,
        "Properties": true,
        "addons/godotfgd": true,
        "addons/godotvmf": true,
        "addons/unary.core.editor/hammer": true,
        "addons/unary.core.editor/scenes": true,
        "addons/unary.core.editor/icons": true,
        "unary.core/analyzers/obj": true,
        "unary.core/analyzers/bin": true,
        "unary.core/ui": true,
        "unary.core/sound": true,
        "unary.core/textures": true,
        "unary.recusant/hammer": true,
        "unary.recusant/levels": true,
        "unary.recusant/resources": true,
        "unary.recusant/scenes": true,
        "unary.recusant/materials": true,
        "unary.recusant/ui": true,
        "unary.testmod1/overrides": true,
        "hammer/": true,
        ".editorconfig": true,
        ".gitattributes": true,
        "**/*.gitignore": true,
        "**/*.gdignore": true,
        "export_presets.cfg": true,
        "icon.svg": true,
        "**/*.import": true,
        "**/*.tres": true,
        "**/*.tscn": true,
        "**/*.godot": true,
        "**/*.dll": true,
        "**/*.tmp": true,
        "**/*.vmf": true,
        "**/*.gd": true,
        "**/*.svg": true,
        "**/*.cfg": true,
        "**/*.csproj": true,
    },
    "git.ignoreLimitWarning": true
}