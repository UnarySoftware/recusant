{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🕹 Debug Game",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${env:GODOT}",
      "args": [
        //"--verbose"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "presentation": {
        "clear": true
      }
    },
    {
      "name": "🎭 Open Editor",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${env:GODOT}",
      "args": [
        "--editor"
      ],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "presentation": {
        "clear": true
      }
    }
  ]
}